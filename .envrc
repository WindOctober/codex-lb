NODE_VERSION="$(tr -d '[:space:]' < .node-version)"
NODE_PREFIX="$PWD/.direnv/node-v$NODE_VERSION"
NODE_BIN="$NODE_PREFIX/node_modules/node/bin"

if [ -x "$NODE_BIN/node" ]; then
  PATH_add "$NODE_BIN"
else
  echo "codex-lb: Node $NODE_VERSION is not installed in .direnv yet."
  echo "codex-lb: run ./scripts/setup-node-direnv.sh, then direnv allow"
fi
